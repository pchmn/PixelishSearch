<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission to query installed apps (Android 11+) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.WEB_SEARCH" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VOICE_COMMAND" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <package android:name="com.google.android.googlequicksearchbox" />
        <package android:name="com.google.android.apps.bard" />
    </queries>

    <!-- Optional permissions -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".PixelishApp"
        android:label="PixelishSearch"
        android:icon="@android:drawable/ic_menu_search"
        android:theme="@style/Theme.PixelishSearch"
        android:allowBackup="true"
        android:supportsRtl="true">

        <!-- Search Activity: transparent, animated from the bottom -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PixelishSearch.Transparent"
            android:windowSoftInputMode="stateAlwaysVisible|adjustResize"
            android:launchMode="singleTask"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Homescreen widget -->
        <receiver
            android:name=".widget.SearchWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- Preloads the index on boot for ultra-fast cold start -->
        <receiver
            android:name=".data.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
