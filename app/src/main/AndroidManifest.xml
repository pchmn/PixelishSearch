<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission to query installed apps (Android 11+) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.WEB_SEARCH" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VOICE_COMMAND" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>

        <package android:name="com.google.android.googlequicksearchbox" />
        <package android:name="com.google.android.apps.bard" />
    </queries>

    <!-- Optional permissions -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Self-update: download an APK from GitHub Releases and hand it to the
         system installer. The runtime grant is requested via the system
         "Install unknown apps" page. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".PixelishSearchApp"
        android:label="@string/app_name"
        android:icon="@android:drawable/ic_menu_search"
        android:theme="@style/Theme.PixelishSearch"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:localeConfig="@xml/locale_config">

        <!-- Search Activity: transparent, animated from the bottom -->
        <activity
            android:name=".search.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PixelishSearch.Transparent"
            android:windowSoftInputMode="stateAlwaysVisible|adjustResize"
            android:launchMode="singleTask"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Settings screen, launched from the search Activity's gear icon -->
        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title"
            android:theme="@style/Theme.PixelishSearch" />

        <!-- Update screen, launched from the badge next to the gear icon when
             a new GitHub release has been detected. -->
        <activity
            android:name=".update.UpdateActivity"
            android:exported="false"
            android:label="@string/update_title"
            android:theme="@style/Theme.PixelishSearch" />

        <!-- Exposes the downloaded APK to the system installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>


        <!-- Homescreen widget -->
        <receiver
            android:name=".widget.SearchWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- Preloads the index on boot for ultra-fast cold start -->
        <receiver
            android:name=".search.apps.data.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Refresh the apps cache on install / uninstall / update so newly
             added apps appear in the search without waiting for the next
             cold start. -->
        <receiver
            android:name=".search.apps.data.PackageReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />

                <data android:scheme="package" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
