<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission pour requêter les apps installées (Android 11+) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <!-- Permissions optionnelles -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".PixelishApp"
        android:label="PixelishSearch"
        android:icon="@android:drawable/ic_menu_search"
        android:theme="@style/Theme.PixelishSearch"
        android:allowBackup="true"
        android:supportsRtl="true">

        <!-- Activity de recherche, transparente, animée depuis le bas -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PixelishSearch.Transparent"
            android:windowSoftInputMode="stateAlwaysVisible|adjustResize"
            android:launchMode="singleTask"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget homescreen -->
        <receiver
            android:name=".widget.SearchWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- Pré-charge l'index au boot pour cold start ultra-rapide -->
        <receiver
            android:name=".data.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
