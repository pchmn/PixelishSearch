<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme. No windowLightStatusBar/Navigation: left to Android,
         which picks based on the system theme via enableEdgeToEdge() in MainActivity. -->
    <style name="Theme.PixelishSearch" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Transparent theme for the search Activity: the wallpaper shows through -->
    <style name="Theme.PixelishSearch.Transparent" parent="Theme.PixelishSearch">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="SlideUpAnimation" parent="@android:style/Animation">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_bottom</item>
    </style>
</resources>
