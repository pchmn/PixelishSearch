<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="@drawable/widget_search_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="16dp">

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_google_logo_themed"
        android:contentDescription="@string/widget_search_hint" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1" />

    <ImageView
        android:id="@+id/widget_gemini"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:src="@drawable/gemini_icon"
        android:tint="@color/on_primary_container"
        android:layout_marginEnd="20dp"
        android:padding="4dp"
        android:contentDescription="Gemini" />

    <ImageView
        android:id="@+id/widget_lens"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:src="@drawable/google_lens_icon"
        android:tint="@color/on_primary_container"
        android:padding="4dp"
        android:contentDescription="Google Lens" />

</LinearLayout>
